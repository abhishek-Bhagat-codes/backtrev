  "curlExamples": {
    "createSOSWithCoordinates": "curl -X POST http://localhost:3000/api/emergency-notifications/sos -H \"Content-Type: application/json\" -H \"Authorization: Bearer YOUR_JWT_TOKEN\" -d '{\"latitude\": 19.0760, \"longitude\": 72.8777, \"currentLocation\": \"Mumbai, Maharashtra\", \"message\": \"Need immediate help!\"}'",
    "createSOSWithoutCoordinates": "curl -X POST http://localhost:3000/api/emergency-notifications/sos -H \"Content-Type: application/json\" -H \"Authorization: Bearer YOUR_JWT_TOKEN\" -d '{}'",
    "fetchAll": "curl -X GET http://localhost:3000/api/sos-notifications -H \"Authorization: Bearer YOUR_JWT_TOKEN\"",
    "fetchSingle": "curl -X GET http://localhost:3000/api/sos-notifications/SOS_NOTIFICATION_ID -H \"Authorization: Bearer YOUR_JWT_TOKEN\""
