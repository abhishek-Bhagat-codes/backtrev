  "testScenarios": [
    {
      "name": "Basic SOS with coordinates",
      "request": {
        "latitude": 19.0760,
        "longitude": 72.8777
      },
      "expectedStatus": 201
    },
    {
      "name": "SOS with message",
      "request": {
        "latitude": 19.0760,
        "longitude": 72.8777,
        "message": "Need immediate help!"
      },
      "expectedStatus": 201
    },
    {
      "name": "SOS without coordinates (uses current location)",
      "request": {},
      "expectedStatus": 201,
      "note": "Requires current location to be set first"
    },
    {
      "name": "SOS without location data",
      "request": {},
      "expectedStatus": 400,
      "note": "Will fail if no current location exists"
    }
  ],
  "notes": {
    "authentication": "All endpoints require JWT token in Authorization header",
    "collection": "SOS notifications are stored in 'sos_notifications' collection",
    "status": "Default status is 'pending'. Can be updated to 'acknowledged' or 'resolved'",
    "locationPriority": "If coordinates provided → use them, else use current location, else error",
    "requiredFields": "At least latitude/longitude OR current location must be available"
  }
}

